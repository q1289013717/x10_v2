# === 生产环境配置 ===
# 复制此文件为 .env 并填入真实值

# PostgreSQL 数据库连接
# 本地: sqlite:///./x10.db
# 云端: postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./x10.db

# JWT 密钥（生产环境务必修改为随机字符串）
SECRET_KEY=x10-engine-secret-key-change-in-production

# JWT 算法
ALGORITHM=HS256

# Token 过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS 允许的前端域名（逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://localhost:5176
